# pnpm config for this monorepo.
#
# auto-install-peers=true makes pnpm act like npm/yarn — it
# automatically installs peer deps declared by packages. Without
# this, Expo SDK modules (expo-router, expo-auth-session, etc.)
# surface their unmet peers as runtime "unable to resolve module"
# errors instead of getting auto-installed.
#
# shamefully-hoist=true flattens the node_modules layout to be
# npm-style instead of pnpm's strict-but-isolated structure. Many
# React Native / Expo tools assume the flat npm layout (Metro,
# react-native CLI, EAS Build's bundler). The name is a
# self-deprecating joke by the pnpm authors; the setting is normal
# and necessary in RN/Expo monorepos.
auto-install-peers=true
shamefully-hoist=true
