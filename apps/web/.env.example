# Copy to .env.local (gitignored).

# Public — embedded in client bundles.
# In Codespaces, this is the API's forwarded URL (port 3000).
# Locally outside Codespaces: http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Server-side — only used by the Next.js server. Same value, separate
# var so we can differ between SSR fetch and client fetch if we ever
# need to (e.g. cluster-internal hostname for SSR).
API_BASE_URL=http://localhost:3000/api/v1
