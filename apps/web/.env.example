# Copy to .env.local (gitignored).

# Public — used by the browser to call the API. Since Next.js proxies
# /api/v1/* to the API (see next.config.mjs rewrites), this should be
# a RELATIVE URL pointing at this same web origin. The browser hits
# the web hostname, Next.js forwards internally to the API.
#
# This is the same on all platforms (Codespaces, localhost, production)
# — the proxy makes the API look like it lives on the web origin.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Server-side — used by server components calling the API during SSR.
# This DOES need to be a full URL since server components don't have
# a window.location to be relative to. Points at the actual API host
# from inside the server (not the proxy).
API_BASE_URL=http://localhost:3000/api/v1

# Where Next.js's rewrite forwards /api/v1/* to. Internal-only;
# the browser never sees this URL.
API_INTERNAL_URL=http://localhost:3000
