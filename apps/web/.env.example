# Copy to .env.local (gitignored).

# Public — embedded in client bundles at build time. Must match the
# URL where your API is reachable FROM THE BROWSER, not from the server.
#
# In Codespaces: your port-3000 forwarded URL (set to Public visibility):
#   NEXT_PUBLIC_API_BASE_URL=https://<your-codespace>-3000.app.github.dev/api/v1
# Locally outside Codespaces:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
#
# NOTE: NEXT_PUBLIC_* vars are inlined at build time. If you change this,
# restart `pnpm dev` for the change to take effect.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Server-side — used only by Next.js server components and route
# handlers. Same value as NEXT_PUBLIC_API_BASE_URL in this project,
# kept separate so we can differ if we ever need to (e.g. an internal
# hostname for SSR fetches in production).
API_BASE_URL=http://localhost:3000/api/v1
