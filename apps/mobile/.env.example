# Copy to .env (gitignored). Expo loads these at start.
#
# Anything prefixed EXPO_PUBLIC_ is inlined into the JS bundle and
# accessible as `process.env.EXPO_PUBLIC_*`. These are also exposed via
# Constants.expoConfig.extra.* in app.config.ts.

# The deployed API base URL. With Option C (Next.js proxy), this is
# the WEB origin, not the DO API origin — the web app proxies /api/v1/*
# back to the API.
#
# In production: https://ref-proj-web.vercel.app/api/v1
# Talking to a local dev API from a phone would require either ngrok
# or running Expo on the same network as the dev API; simplest path
# for this reference project is to point at production.
EXPO_PUBLIC_API_BASE_URL=https://ref-proj-web.vercel.app/api/v1

# Google OAuth client IDs from the ref-proj-prod project in Google
# Cloud Console.
#
# WEB client ID: used by Android (eventually) and as a fallback. Same
# value as the API's GOOGLE_CLIENT_ID. Looks like
# 670220272975-xxxxxx.apps.googleusercontent.com.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# iOS client ID: required for native iOS sign-in in dev/production
# builds. Created as type "iOS" in Google Console with bundle ID
# com.mgavr.refproj (matches ios.bundleIdentifier in app.config.ts).
# iOS clients have no client secret. Looks like
# 670220272975-yyyyyy.apps.googleusercontent.com.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
