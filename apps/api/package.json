{
  "name": "@refproj/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "pnpm --filter @refproj/types --filter @refproj/api-client build && prisma migrate deploy && prisma generate && nest start --watch",
    "start": "node dist/main.js",
    "lint": "echo \"lint: not configured yet\" && exit 0",
    "test": "echo \"test: not configured yet\" && exit 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:new": "prisma migrate dev --create-only",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "@prisma/client": "6.2.1",
    "@refproj/api-client": "workspace:*",
    "@refproj/types": "workspace:*",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "prisma": "6.2.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
