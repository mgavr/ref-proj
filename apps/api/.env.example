# Copy to .env (which is gitignored) and adjust.
# Validated by apps/api/src/config/env.ts on boot.

NODE_ENV=development
PORT=3000

# Local Postgres (from infra/docker-compose.dev.yml).
# sslmode=disable is required for Prisma Studio to connect against the
# local Docker Postgres — Studio opportunistically tries TLS even on
# loopback addresses unless told otherwise. The main Prisma client
# works either way. When deploying to DigitalOcean's managed Postgres,
# replace `sslmode=disable` with `sslmode=require` (managed Postgres
# enforces TLS).
DATABASE_URL=postgresql://refproj:refproj_dev@localhost:5432/refproj?schema=public&sslmode=disable

# ---- API public URL ----
# The URL where this API is reachable from the public internet. This is
# what we register with Google as the OAuth redirect URI base. It MUST
# match the "Authorized redirect URI" in Google Cloud Console exactly
# (apart from the /api/v1/auth/google/callback path we append).
#
# In Codespaces: your port-3000 forwarded URL, with port 3000 set to
# Public visibility.
# Locally outside Codespaces: http://localhost:3000
API_PUBLIC_URL=http://localhost:3000

# ---- Web origin ----
# The URL of the web frontend (Next.js, port 3001). This is where we
# redirect users *back* to after a successful OAuth callback, and the
# CORS origin we allow for fetch requests from the web app.
#
# In Codespaces: your port-3001 forwarded URL (set to Public visibility).
# Locally outside Codespaces: http://localhost:3001
WEB_ORIGIN=http://localhost:3001

# Cookie Domain attribute. Leave empty for host-only cookies (the default,
# correct for Codespaces and localhost). In production set to your
# shared eTLD+1 (e.g. .refproj.example) so web and api subdomains both
# see the cookies.
# COOKIE_DOMAIN=

# ---- JWT signing secrets ----
# THESE DEFAULTS ARE FOR LOCAL DEVELOPMENT ONLY. Replace with `openssl rand
# -hex 32` output in any non-dev environment. Each must be at least 32 chars.
JWT_ACCESS_SECRET=dev_access_secret_change_me_at_least_32_chars_long_xx
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_at_least_32_chars_long_xx
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ---- Google OAuth ----
# From https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client
# IDs of type "Web application". The redirect URI on that client must be
# exactly  <WEB_ORIGIN or API host>/api/v1/auth/google/callback .
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Dev only ----
# UUID of the user the (now-unused) FakeAuthGuard treats as "currently
# logged in" when no X-Fake-User-Id header is sent. Still seeded by
# prisma/seed.ts; safe to leave set.
DEV_FAKE_USER_ID=00000000-0000-4000-8000-000000000001
