# Copy to .env (which is gitignored) and adjust.
# Validated by apps/api/src/config/env.ts on boot.

NODE_ENV=development
PORT=3000

# Local Postgres (from infra/docker-compose.dev.yml).
DATABASE_URL=postgresql://refproj:refproj_dev@localhost:5432/refproj?schema=public

# UUID of the user the FakeAuthGuard treats as "currently logged in"
# when no X-Fake-User-Id header is sent. Must match a row in the users
# table \u2014 prisma/seed.ts creates this user on `pnpm db:seed`.
# Removed when real OAuth lands in step 4.
DEV_FAKE_USER_ID=00000000-0000-4000-8000-000000000001
